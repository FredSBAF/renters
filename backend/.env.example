# == SERVEUR ==
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
# Optional: extra allowed origins (comma-separated). In development, http://localhost:* and 127.0.0.1:* are also allowed.
# CORS_ORIGINS=http://localhost:8080
API_BASE_URL=http://localhost:3001

# == BASE DE DONNÉES ==
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pouraccord_dev
DB_USER=pouraccord
DB_PASSWORD=change_me

# == JWT ==
JWT_SECRET=change_me_to_a_random_string_of_at_least_32_characters
JWT_EXPIRES_IN=86400
JWT_REFRESH_SECRET=change_me_to_another_random_string_32_chars
JWT_REFRESH_EXPIRES_IN=604800

# == AWS S3 ==
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-3
AWS_S3_BUCKET=pouraccord-documents-dev
MAX_FILE_SIZE_MB=5
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png

# == EMAIL (SendGrid) ==
SENDGRID_API_KEY=SG.change_me
EMAIL_FROM=noreply@pouraccord.com
EMAIL_FROM_NAME=PourAccord
# Local dev without SendGrid: set true (ignored in production). Registration still works; check logs for links.
# EMAIL_DISABLE_SEND=true

# == 2FA TOTP ==
TOTP_SECRET_ENCRYPTION_KEY=_me_to_exactly_32_characters!!!!

# == STRIPE ==
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_PRICE_ID=price_change_me
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# == MICROSERVICE IA ==
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=change_me
AI_SERVICE_TIMEOUT_MS=30000
AI_SCORE_AUTO_VALIDATE=80
AI_SCORE_MANUAL_REVIEW=40
ANTHROPIC_API_KEY=sk-ant-change_me

# == PARTAGE ==
SHARING_LINK_EXPIRY_DAYS=30
SHARING_LINK_BASE_URL=https://renters.app/view

# == RATE LIMITING ==
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
GDPR_FOLDER_EXPIRY_MONTHS=6
GDPR_ACCOUNT_GRACE_DAYS=30
GDPR_AUDIT_LOG_ANONYMIZE_YEARS=3
GDPR_EXPORT_LINK_EXPIRY_HOURS=24
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_UPLOAD_WINDOW_MS=3600000
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_SHARING_WINDOW_MS=3600000
RATE_LIMIT_SHARING_MAX=10
RATE_LIMIT_EXPORT_WINDOW_MS=86400000
RATE_LIMIT_EXPORT_MAX=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=3600000
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
RATE_LIMIT_API_AGENCY_WINDOW_MS=60000
RATE_LIMIT_API_AGENCY_MAX=60
